# Copy this file to `.env` and adjust values for local development.
# Production should set real environment variables instead of committing `.env`.

# Application identity
APP_NAME=api_sapaai_crm

# Server binding
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=5790

# MySQL connection
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=crm_sapaai
DATABASE_USERNAME=root
DATABASE_PASSWORD=

# Optional full URL (overrides the variables above)
# DATABASE_URL=mysql://root:@127.0.0.1:3306/crm_sapaai

# Public base URL for generated links to uploaded files
SERVER_BASE_URL=http://localhost:5790

# Logging verbosity. Examples: error, warn, info, debug, trace.
RUST_LOG=info,api_sapaai=debug,whatsapp_rust=debug,wacore=debug
